{
  "appId": "com.ecosyntech.smartfarm",
  "appName": "EcoSynTech",
  "webDir": "www",
  "bundledWebDir": "./android/app/src/main/assets/public",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": true,
    "minSdkVersion": 24,
    "targetSdkVersion": 33,
    "compileSdkVersion": 33,
    "buildToolsVersion": "33.0.2"
  },
  "ios": {
    "minVersion": "12.0"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchShowOriginalDuration": 3000,
      "launchFadeOutDuration": 3000,
      "backgroundColor": "#219465",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "spinnerColor": "#ffffff"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}