# EcoSynTech FarmOS - Production Environment Variables
# Copy this file to .env and update with your values

# ===================
# REQUIRED
# ===================

# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# ===================
# SERVER
# ===================

NODE_ENV=production
PORT=3000

# ===================
# DATABASE
# ===================

DB_PATH=./data/ecosyntech.db

# ===================
# MQTT Broker (nếu dùng broker riêng)
# ===================

MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
MQTT_USERNAME=
MQTT_PASSWORD=

# ===================
# RATE LIMITING
# ===================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================
# LOGGING
# ===================

LOG_LEVEL=info

# ===================
# CORS
# ===================

CORS_ORIGIN=https://your-domain.com

# ===================
# WEBHOOK SECRET
# ===================

WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ===================
# ENCRYPTION KEY (nếu dùng encryption)
# ===================

ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY

# ===================
# OPTIONAL
# ===================

# Redis (nếu dùng)
# REDIS_URL=redis://redis:6379

# S3 for backup
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=

# Email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Monitoring
# SENTRY_DSN=